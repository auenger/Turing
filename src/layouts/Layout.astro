---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = '硅基源流 SiliconSource · 把 Agent 放进真实业务流程',
  description = '硅基源流 SiliconSource 以 Agent 特区承接 AI 战略，由 FDE 团队嵌入业务现场，把试点放进有边界的真实工作，交付可运行、可衡量、可复盘的业务流程。',
} = Astro.props;
const base = import.meta.env.BASE_URL;
const publicAsset = (path: string) => `${base.replace(/\/$/, '')}/${path}`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" href={publicAsset('favicon.ico')} sizes="any" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#f6f7fa" />
    <script is:inline>
      try {
        const savedTheme = localStorage.getItem('siliconsource-theme');
        const theme = savedTheme === 'dark' ? 'dark' : 'light';
        document.documentElement.dataset.theme = theme;
        document.querySelector('meta[name="theme-color"]')?.setAttribute('content', theme === 'dark' ? '#11131a' : '#f6f7fa');
      } catch {
        document.documentElement.dataset.theme = 'light';
      }
    </script>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      // 滚动入场：进入视口后添加 reveal-in
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('reveal-in');
              io.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.12, rootMargin: '0px 0px -6% 0px' }
      );
      document.querySelectorAll('[data-reveal]').forEach((el) => io.observe(el));
    </script>
  </body>
</html>
